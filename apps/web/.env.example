# Firebase Client SDK (público)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (servidor - stringified JSON del service account)
FIREBASE_SERVICE_ACCOUNT_KEY=

# IA — Gemini (principal) y Groq (fallback automático si Gemini falla por cuota)
GEMINI_API_KEY=
GROQ_API_KEY=

# Ranking local de guerra — seed para cuando el clan está fuera del top 200
# (se usa CLAN_WAR_RANK_FALLBACK del entorno si está definido, sino usa el valor guardado en Firestore)
CLAN_WAR_TROPHIES_FALLBACK=2720
CLAN_WAR_CHANGE_FALLBACK=102
